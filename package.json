{
  "name": "furnza-orders",
  "version": "0.1.0",
  "private": true,
  "description": "Furnza — Delivered Orders & Customer Management System (Next.js 16 + Supabase)",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write .",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff",
    "db:types": "supabase gen types typescript --local > src/lib/supabase/database.types.ts",
    "db:types:remote": "supabase gen types typescript --linked > src/lib/supabase/database.types.ts",
    "seed": "tsx --env-file=.env scripts/seed.ts",
    "seed:bulk": "tsx --env-file=.env scripts/seed-bulk.ts",
    "analytics:refresh": "tsx --env-file=.env scripts/refresh-analytics.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@hookform/resolvers": "^3.9.1",
    "@react-pdf/renderer": "^4.1.6",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-virtual": "^3.14.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "motion": "^11.15.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "papaparse": "^5.4.1",
    "radix-ui": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.1",
    "recharts": "^2.15.0",
    "server-only": "^0.0.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.0.1",
    "tw-animate-css": "^1.2.5",
    "vaul": "^1.1.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@faker-js/faker": "^9.3.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "supabase": "^2.2.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.0"
  }
}
