# ──────────────────────────────────────────────────────────────────────────
# Furnza — environment variables. Copy to `.env` and fill in real values.
# NEVER commit `.env`. No secrets belong in source control.
# ──────────────────────────────────────────────────────────────────────────

# Supabase --------------------------------------------------------------------
# LOCAL: run `supabase start`, then `supabase status` prints these three values.
# CLOUD: Project Settings → API (URL + anon public key + service_role secret).
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-anon-key>"
# Server-only. BYPASSES RLS. NEVER expose to the browser / commit to git.
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"

# App -------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI assistant (dashboard "Ask Furnza" chat box) ------------------------------
# Server-only Anthropic API key. Leave empty to disable the assistant (the chat
# box shows a "not configured" notice). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=""
# Optional model override. Defaults to claude-opus-4-8 (most capable). Set to
# claude-sonnet-4-6 or claude-haiku-4-5 for lower latency/cost.
ANTHROPIC_MODEL="claude-opus-4-8"

# Seed: default Admin account (created by `npm run seed`). CHANGE before prod.
SEED_ADMIN_EMAIL="admin@furnza.local"
SEED_ADMIN_PASSWORD="ChangeMe!2026"
SEED_ADMIN_NAME="Admin"

# Optional bulk/scale seed sizes (`npm run seed:bulk`) — generates faker data
# in chunks of 1,000. Tune for performance testing toward the 1M-customer target.
SEED_BULK_CUSTOMERS="50000"
SEED_BULK_ORDERS="200000"

# Cron runner auth -----------------------------------------------------------
# Shared secret for POST /api/cron (print countdowns, chat scheduler, campaigns,
# automation). Invoke every minute:
#   curl -X POST $APP_URL/api/cron -H "Authorization: Bearer $CRON_SECRET"
CRON_SECRET="<generate-a-long-random-secret>"

# Marketing channel providers --------------------------------------------------
# Leave a provider's keys EMPTY to use the built-in dev adapter, which logs the
# rendered message to the server console — the app runs fully without accounts.
MARKETING_EMAIL_PROVIDER="console"        # console | resend
RESEND_API_KEY=""
MARKETING_EMAIL_FROM="Furnza <no-reply@furnza.local>"
MARKETING_SMS_PROVIDER="console"          # console | twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
MARKETING_WHATSAPP_PROVIDER="console"     # console | twilio
TWILIO_WHATSAPP_FROM=""
